{
  "name": "zonot",
  "private": true,
  "version": "0.0.0",
  "description": "A clear place to drop your thinking, where everything you keep stays connected below the surface.",
  "license": "FSL-1.1-ALv2",
  "author": "Chris Horne <cdh612@gmail.com>",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "build": "pnpm -r --parallel build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.2"
  }
}
