{
  "name": "zonot",
  "version": "0.0.0",
  "type": "module",
  "description": "Zonot CLI — calm capture, deep notes, plain Markdown in your own GitHub repo.",
  "license": "FSL-1.1-ALv2",
  "bin": {
    "zonot": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "dev": "bun run ./src/index.ts",
    "build": "bun run build:npm",
    "build:npm": "bun build ./src/index.ts --target bun --outfile ./dist/index.js",
    "build:bin": "bun build ./src/index.ts --compile --outfile ./dist/zonot",
    "build:dist": "bun scripts/build-binaries.ts",
    "prepublishOnly": "bun run build:npm"
  },
  "devDependencies": {
    "@zonot/core": "workspace:*",
    "isomorphic-git": "^1.38.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
