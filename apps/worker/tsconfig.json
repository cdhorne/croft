{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./.tsbuild",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../../packages/core" }],
  "exclude": ["dist", ".tsbuild", "node_modules", "**/*.test.ts", "**/__tests__/**"]
}
